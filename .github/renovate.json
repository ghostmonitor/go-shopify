{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":automergeDisabled",
    ":automergeMinor",
    "group:linters",
    "schedule:automergeNonOfficeHours",
    "schedule:nonOfficeHours",
    "docker:disable",
    "group:definitelyTyped"
  ],
  "hostRules": [
    {
      "hostType": "npm",
      "matchHost": "registry.npmjs.org",
      "token": "{{ secrets.NPM_READ_TOKEN }}"
    },
    {
      "matchHost": "https://github.com/ghostmonitor",
      "hostType": "go",
      "token": "{{ secrets.GHOSTMONITOR_GITHUB_TOKEN }}"
    },
    {
      "matchHost": "https://api.github.com/repos/ghostmonitor",
      "hostType": "github",
      "token": "{{ secrets.GHOSTMONITOR_GITHUB_TOKEN }}"
    }
  ],
  "lockFileMaintenance": {
    "enabled": false
  },
  "rangeStrategy": "pin",
  "ignoreDeps": [
    "dd-trace",
    "microbundle",
    "node",
    "@ghostmonitor/lib-worker",
    "ua-parser-js"
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "**/bower_components/**",
    "**/vendor/**",
    "**/examples/**",
    "**/__tests__/**",
    "**/test/**",
    "**/tests/**",
    "**/__fixtures__/**",
    "**/scripts/**"
  ],
  "timezone": "Europe/Budapest",
  "updateNotScheduled": false,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true,
      "minimumReleaseAge": "14 days"
    },
    {
      "matchPackagePatterns": [
        "react"
      ],
      "groupName": "react packages"
    },
    {
      "matchPackagePatterns": [
        "^@ghostmonitor/lib-"
      ],
      "groupName": "recart-modules"
    },
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "matchPackageNames": [
        "@ghostmonitor/**"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true,
      "minimumReleaseAge": null
    }
  ],
  "npmToken": "{{ secrets.NPM_READ_TOKEN }}",
  "env": {
    "GOPRIVATE": "github.com/ghostmonitor/*",
    "GONOSUMDB": "github.com/ghostmonitor/*",
    "GONOPROXY": "github.com/ghostmonitor/*",
    "GOPROXY": "direct"
  },
  "postUpdateOptions": [
    "gomodTidy"
  ]
}